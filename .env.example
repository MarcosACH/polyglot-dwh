# Plantilla de variables de entorno para BUSCASAM DWH.
# Copiar a .env (gitignored) y completar con credenciales reales.

# PostgreSQL / Supabase — pooler connection string (modo session, puerto 5432)
# Dashboard -> Project Settings -> Database -> Connection string (URI)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres"

# Redis Cloud — connection URL (soporta rediss:// para TLS)
REDIS_URL="redis://default:<password>@<host>:<port>"
